REDIS_URL=redis://redis:6379/0

# Bybit WebSocket: false = mainnet, true = testnet (pybit)
BYBIT_TESTNET=false

# Triangle paths start from these coins (comma-separated). Spot pairs are loaded from Bybit API.
TRIANGLE_START_COINS=USDT,BTC,ETH,USDC

TAKER_FEE_BPS=5.5
SLIPPAGE_BPS_BUFFER=10

PRINT_EVERY_SEC=1
TOP_N=15
EDGE_THRESHOLD_BPS=2
MAX_STALE_MS=1500

# Telegram (optional; leave empty to disable)
TELEGRAM_BOT_TOKEN=<YOUR TOKEN HERE>
TELEGRAM_CHAT_ID=<YOUR CHAT ID HERE>

# Debug mode: true/false — print data collection, calculations, etc. to console
DEBUG_MODE=false

# Save average net edge to Redis every minute (for charts / moving averages). Keeps last 1440 minutes (24h).
SAVE_TO_DB=false
AVG_NET_RETENTION_MINUTES=1440
